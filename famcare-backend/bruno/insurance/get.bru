meta {
  name: Get insurance card
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/v1/insurance/{{insuranceId}}
  body: none
  auth: none
}

headers {
  x-line-userid: {{ownerUserId}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("expirationDate is Bangkok ISO", function() {
    expect(res.body.data.expirationDate).to.match(/\+07:00$/);
  });
}
