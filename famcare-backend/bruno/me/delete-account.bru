meta {
  name: Delete /me — PDPA hard delete
  type: http
  seq: 99
}

delete {
  url: {{baseUrl}}/api/v1/me
  body: none
  auth: none
}

headers {
  x-line-userid: test-user-tombstone
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("deleted flag returned", function() {
    expect(res.body.data.deleted).to.equal(true);
  });
}
