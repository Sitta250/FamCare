meta {
  name: Patch emergency contact
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/api/v1/family-members/{{memberId}}/emergency-contacts/{{emergencyContactId}}
  body: json
  auth: none
}

headers {
  x-line-userid: {{ownerUserId}}
}

body:json {
  {
    "phone": "+66899999999"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("phone updated", function() {
    expect(res.body.data.phone).to.equal("+66899999999");
  });
}
