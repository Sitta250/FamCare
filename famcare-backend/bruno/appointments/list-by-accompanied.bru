meta {
  name: List appointments — filter by accompaniedByUserId
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/api/v1/appointments?accompaniedByUserId={{caregiverUserId}}&view=upcoming
  body: none
  auth: none
}

headers {
  x-line-userid: {{caregiverUserId}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("data is array", function() {
    expect(res.body.data).to.be.an("array");
  });
}
