meta {
  name: List appointments — view=calendar (grouped)
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/v1/appointments?familyMemberId={{memberId}}&view=calendar
  body: none
  auth: none
}

headers {
  x-line-userid: {{ownerUserId}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("data is an object (grouped by yyyy-mm-dd)", function() {
    expect(res.body.data).to.be.an("object");
  });
}
