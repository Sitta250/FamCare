meta {
  name: List family members
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/family-members
  body: none
  auth: none
}

headers {
  x-line-userid: {{ownerUserId}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("data is an array", function() {
    expect(res.body.data).to.be.an("array");
  });
}
