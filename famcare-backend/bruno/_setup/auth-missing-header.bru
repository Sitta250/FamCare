meta {
  name: Auth — missing header returns 401
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/me
  body: none
  auth: none
}

tests {
  test("status is 401", function() {
    expect(res.status).to.equal(401);
  });
  test("returns UNAUTHORIZED code", function() {
    expect(res.body.code).to.equal("UNAUTHORIZED");
  });
}
