meta {
  name: Get document
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/v1/documents/{{documentId}}
  body: none
  auth: none
}

headers {
  x-line-userid: {{ownerUserId}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("createdAt is Bangkok ISO", function() {
    expect(res.body.data.createdAt).to.match(/\+07:00$/);
  });
}
