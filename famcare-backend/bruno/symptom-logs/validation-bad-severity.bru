meta {
  name: Create symptom log — bad severity returns 400
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/symptom-logs
  body: json
  auth: none
}

headers {
  x-line-userid: {{ownerUserId}}
}

body:json {
  {
    "familyMemberId": "{{memberId}}",
    "description": "ปวดหัว",
    "severity": 99
  }
}

tests {
  test("status is 400", function() {
    expect(res.status).to.equal(400);
  });
  test("code is BAD_REQUEST", function() {
    expect(res.body.code).to.equal("BAD_REQUEST");
  });
}
